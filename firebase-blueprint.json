{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "createdAt": { "type": "string", "format": "date-time", "description": "The timestamp when the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "NewsAnalysis": {
      "title": "News Analysis",
      "description": "Stores the results of a news verification analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID for the analysis." },
        "userId": { "type": "string", "description": "The UID of the user who performed the analysis." },
        "newsText": { "type": "string", "description": "The original news text or URL analyzed." },
        "confidenceScore": { "type": "number", "description": "Confidence score from 0 to 100." },
        "verdict": { "type": "string", "enum": ["TRUE", "FALSE", "MISLEADING", "UNVERIFIED"], "description": "The final verdict." },
        "explanation": { "type": "string", "description": "Detailed explanation of the verdict." },
        "pros": { "type": "array", "items": { "type": "string" }, "description": "Points supporting the news." },
        "cons": { "type": "array", "items": { "type": "string" }, "description": "Points debunking the news." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the analysis was performed." }
      },
      "required": ["userId", "newsText", "confidenceScore", "verdict"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Private user profile data."
    },
    "/analyses/{analysisId}": {
      "schema": "NewsAnalysis",
      "description": "History of news analyses performed by users."
    }
  }
}
